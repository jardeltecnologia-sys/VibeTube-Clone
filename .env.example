# SpeedVox configuration — copy to .env and fill in.

# HTTP port
PORT=3000

# Public base URL of this server (used for OAuth redirect + media links)
PUBLIC_URL=http://localhost:3000

# Secret used to sign JWT session tokens. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# --- Web Push (optional) ---
# If left blank, a VAPID key pair is generated and persisted to data/vapid.json
# on first boot. Set these to pin a stable key pair across deployments.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@speedvox.app

# --- Google Sign-In (optional) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: {PUBLIC_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
